# ---- App ----
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
# JSON array or comma string; pydantic-settings parses JSON
CORS_ORIGINS=["http://localhost:3000"]

# ---- Datastores (the only DB is Postgres+pgvector; Redis is short-term memory) ----
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/support
REDIS_URL=redis://localhost:6379/0
# Create tables on startup (dev only; otherwise run scripts/init_db.py)
DB_AUTO_CREATE=false

# ---- LLM provider (Gemini only) ----
# Free key at https://aistudio.google.com/apikey . Chat only; embeddings run locally.
GEMINI__API_KEY=
GEMINI__MODEL=gemini-2.5-flash

# ---- Auth (JWT) ----
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ---- RAG (pgvector + local embeddings) ----
RAG__EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG__EMBEDDING_DIM=384
RAG__CHUNK_SIZE=800
RAG__CHUNK_OVERLAP=150
RAG__TOP_K=4
RAG__KNOWLEDGE_DIR=data/knowledge

# ---- Observability (LangSmith tracing; optional, off by default) ----
# Get a key at https://smith.langchain.com . Tracing runs only when TRACING=true AND a key is set.
LANGSMITH__TRACING=false
LANGSMITH__API_KEY=
LANGSMITH__PROJECT=ecommerce-support-chatbot
LANGSMITH__ENDPOINT=https://api.smith.langchain.com

# ---- Agent / memory ----
MAX_AGENT_ITERATIONS=6
CONVERSATION_TTL_SECONDS=86400
MEMORY_ENABLED=true

# ---- Logging ----
LOG_FILE=logs/logger.log
